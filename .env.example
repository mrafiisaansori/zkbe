# Server (JANGAN isi PORT di hosting cPanel/Passenger - biarkan kosong)
PORT=
# Base URL backend publik, dipakai untuk X-Override-Notification Midtrans.
# Contoh: https://api.zonakasir.com
APP_URL=

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=

# Basic Auth (hanya untuk Swagger /api-docs)
BASIC_AUTH_USERNAME=admin
BASIC_AUTH_PASSWORD=ganti-password-kuat

# JWT (WAJIB diganti di production - string acak panjang >= 32 karakter)
JWT_SECRET=ganti-secret-acak-panjang
JWT_EXPIRES_IN=12h

# SMTP (isi di .env server, JANGAN commit nilai asli)
SMTP_HOST=mail.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=email@example.com
SMTP_PASS=
SMTP_FROM_EMAIL=email@example.com
SMTP_FROM_NAME=Zona Kasir

# OTP
OTP_TTL_MINUTES=10
OTP_RESEND_COOLDOWN=60
OTP_MAX_ATTEMPTS=5

# Feature flag
FEATURE_QR_ORDER=false

# Cloudflare Turnstile SECRET KEY (verifikasi form publik).
# Kosongkan di lokal -> verifikasi DILEWATI (dev lancar).
# Isi di production -> semua endpoint auth publik wajib token Turnstile valid.
TURNSTILE_SECRET_KEY=

# =====================================================================
# Midtrans (Payment Gateway QRIS Dinamis) - KHUSUS plan BUSINESS.
# Ambil dari dashboard Midtrans: Settings > Access Keys.
# SERVER_KEY hanya dipakai di backend (charge + verifikasi signature webhook).
# JANGAN expose SERVER_KEY ke frontend. CLIENT_KEY boleh dipakai frontend.
# Untuk demo gunakan akun SANDBOX dan biarkan MIDTRANS_IS_PRODUCTION=false.
# =====================================================================
MIDTRANS_MERCHANT_ID=
MIDTRANS_CLIENT_KEY=
MIDTRANS_SERVER_KEY=
MIDTRANS_IS_PRODUCTION=false

# =====================================================================
# Midtrans khusus Billing Upgrade Plan (PRO/BUSINESS).
# Gunakan akun Midtrans penerima pembayaran langganan Zona Kasir.
# SERVER_KEY hanya dibaca backend dan tidak pernah dikirim ke frontend.
# Jika akun Midtrans sama untuk POS + billing, pakai Notification URL gabungan:
# {APP_URL}/api/midtrans/notification
# URL lama tetap tersedia: {APP_URL}/api/subscription/midtrans/notification
# =====================================================================
BILLING_MIDTRANS_UPGRADE_PLAN_MERCHANT_ID=
BILLING_MIDTRANS_UPGRADE_PLAN_CLIENT_KEY=
BILLING_MIDTRANS_UPGRADE_PLAN_SERVER_KEY=
BILLING_MIDTRANS_UPGRADE_PLAN_IS_PRODUCTION=false

# =====================================================================
# WA Gateway (wazapp.web.id) - kirim struk via WhatsApp, khusus plan PRO ke atas.
# WAGATEWAY_API_KEY = API key akun tenant "zonakasir", generate dari dashboard
# wazapp.web.id > menu API Key (BUKAN password login - kalau bocor, cabut dari
# situ saja tanpa perlu ganti password akun).
# =====================================================================
WAGATEWAY_URL=https://wazapp.web.id
WAGATEWAY_API_KEY=
