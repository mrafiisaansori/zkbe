# Server
PORT=3000
APP_URL=

# Database (gunakan database yang sama dengan POS CodeIgniter existing)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=lavenia1_pos

# Basic Auth (kini hanya untuk Swagger /api-docs)
BASIC_AUTH_USERNAME=admin
BASIC_AUTH_PASSWORD=rahasia

# JWT - identitas user multi-tenant (WAJIB diganti di production!)
JWT_SECRET=ubah-secret-acak-panjang-ini
JWT_EXPIRES_IN=12h

# SMTP untuk email OTP registrasi merchant
SMTP_HOST=mail.raftechsolution.web.id
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=linkatalog@raftechsolution.web.id
SMTP_PASS=
SMTP_FROM_EMAIL=linkatalog@raftechsolution.web.id
SMTP_FROM_NAME=Linkatalog

# OTP
OTP_TTL_MINUTES=10
OTP_RESEND_COOLDOWN=60
OTP_MAX_ATTEMPTS=5
